# =========================================================================
# Scrapper Pro - Environment Configuration Template
# =========================================================================
# Copy this file to a new file named '.env' and fill in your actual keys.
# Do NOT commit your actual '.env' file containing secrets to Git/GitHub.

# Apify API Token (Required for LinkedIn job scraping)
# Get your token from: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_api_token_here

# Groq API Key (Required for ATS parsing, email drafting, and Pro-Max scoring)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Authentication Credentials
ADMIN_USERNAME=
ADMIN_PASSWORD=
